@page "/order/details/{Id:int}"
@using System.Globalization
@inject OrderDetailsVM VM

@if (VM.IsProcessing)
{
    <div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}
else
{
    <div class="container my-5 mx-auto p-5 w-100" style="max-width: 950px;">
        <div class="card" style="max-width: 750px;">
            <div class="pt-3 text-success text-center">
                <span class="h4"> ORDER DETAILS</span>
            </div>

            <hr />
            <div class="px-3">
                <p>Order Id: @VM.OrderHeader!.Id</p>
                <p>Name: @VM.OrderHeader!.Name</p>
                <p>Email: @VM.OrderHeader!.Email</p>
                <p>Phone: @VM.OrderHeader!.PhoneNumber</p>
                <p>Order Status:  @VM.OrderHeader!.Status</p>
            </div>
            <hr />
            <div class="card-body">
                <h4 class="text-success">Menu Items</h4>

                @foreach(var details in VM.OrderHeader.OrderDetails)
                {
                    <div class="d-flex">
                        <div class="d-flex w-100 justify-content-between">
                            <p>
                                &nbsp; -- @details.ProductName
                            </p>
                            <p>
                                @details.Price.ToString("C", CultureInfo.GetCultureInfo("fr-ca")) x @details.Count = 
                                <span style="white-space: nowrap" >
                                    @((@details.Price * @details.Count).ToString("C", CultureInfo.GetCultureInfo("fr-ca")))
                                </span>
                            </p>
                        </div>
                    </div>
                }

                <hr />
                <h4 class="text-success text-end">
                    @VM.OrderHeader.OrderTotal.ToString("C", CultureInfo.GetCultureInfo("fr-ca"))
                </h4>
                <hr />

                <div class="row">
                    <div class="col-5">
                        <a href="order/list" class="btn btn-secondary  m-2 p-2" style="width:150px;">Back to Orders</a>
                    </div>
                    <div class="col-7 text-end">
                        @if(VM.OrderHeader.Status!=SD.StatusCancelled 
                            && VM.OrderHeader.Status != SD.StatusCompleted 
                            && VM.IsAdmin) 
                        {
                            <button class="btn btn-danger m-2 p-2" @onclick="()=>VM.UpdateStatusAsync(SD.StatusCancelled)" style="width:150px;">Cancel Order</button>

                            @if (VM.OrderHeader.Status == SD.StatusApproved)
                            {
                                <button class="btn btn-primary m-2 p-2" @onclick="() => VM.UpdateStatusAsync(SD.StatusReadyForPickUp)" style="width:150px;">Ready for Pickup</button>
                            }
                            @if (VM.OrderHeader.Status == SD.StatusReadyForPickUp)
                            {
                                <button class="btn btn-success m-2 p-2" @onclick="() => VM.UpdateStatusAsync(SD.StatusCompleted)" style="width:150px;">Completed</button>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

}

@code {
    [Parameter]
    public int Id { get; set; }

    protected override void OnInitialized()
    {
        VM.StateChanged = StateHasChanged;
        VM.Id = Id;
    }

    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await VM.AfterRenderAsync(firstRender);
    }
}