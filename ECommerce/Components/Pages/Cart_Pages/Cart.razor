@page "/cart"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@inject CartVM VM
@attribute [Authorize]

@if (VM.IsProcessing)
{
	<div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center">
		<img src="/images/loading.gif" alt="loading" />
	</div>
}
else
{
	@if(VM.ShoppingCarts.Any())
	{
		<div class="row w-100">
			<div class="col-lg-6 col-12">
				<div class="container p-4 m-2">
					<h4 class="text-center text-success display-6">
						Cart Summary
					</h4>

					@foreach (var cartItem in VM.ShoppingCarts)
					{
						<div class="d-flex p-2 m-2">
							<div class="card flex-row w-100">
								<img class="card-img-left" style="width: 120px;" src="@(cartItem.Product.ImageUrl ?? "/images/default.png")">
								<div class="card-body">
									<div class="d-flex justify-content-between align-items-center">
										<h4 class="">
											@cartItem.Product.Name
										</h4>
										<h4>
											@cartItem.Product.Price.ToString("C", CultureInfo.GetCultureInfo("fr-ca"))
										</h4>
									</div>
									<div class="flex-fill">
										<h4 class="text-danger">
											@((cartItem.Product.Price * cartItem.Count).ToString("C", CultureInfo.GetCultureInfo("fr-ca")))
										</h4>
									</div>
									<div class="d-flex justify-content-between align-items-center">
										<div class="d-flex justify-content-between g-0">
											<span @onclick="() => VM.UpdateCartItemAsync(cartItem.ProductId, -1)">
												<i class="bi bi-dash-circle-fill btn text-secondary"></i>
											</span>
											<span class="ml-1 me-1">
												<b class="lead">@cartItem.Count</b>
											</span>
											<span @onclick="() => VM.UpdateCartItemAsync(cartItem.ProductId, 1)">
												<i class="bi bi-plus-circle-fill btn text-secondary"></i>
											</span>
										</div>
										<button class="btn btn-danger"
												@onclick="() => VM.UpdateCartItemAsync(cartItem.ProductId, -10000)">
												Remove
										</button>
									</div>
								</div>
							</div>
						</div>
					}

				</div>
			</div>
			<div class="col-lg-6 col-12 p-4">
				<div class="card">
					<div class="card-header text-success text-center display-6">
						Pickup Details
					</div>
					<EditForm Model="VM.OrderHeader" FormName="CartForm" OnValidSubmit="VM.ProcessOrderCreationAsync">
						<DataAnnotationsValidator />
						<div class="card-body">
	
							<div class="form-group">
								<label>Name</label>
								<InputText @bind-Value="VM.OrderHeader.Name" type="text" class="form-control" />
								<ValidationMessage For="@(() => VM.OrderHeader.Name)" />
							</div>
							<div class="form-group">
								<label>Email</label>
								<InputText @bind-Value="VM.OrderHeader.Email" type="text" class="form-control" />
								<ValidationMessage For="@(() => VM.OrderHeader.Email)" />
							</div>
							<div class="form-group">
								<label>Phone</label>
								<InputText @bind-Value="VM.OrderHeader.PhoneNumber" type="text" class="form-control" />
								<ValidationMessage For="@(() => VM.OrderHeader.PhoneNumber)" />
							</div>

							<div class="card mt-4 bg-light">
								<div class="card-body">
									<h4>
										Grand Total: @VM.OrderHeader.OrderTotal.ToString("C", CultureInfo.GetCultureInfo("fr-ca"))
									</h4>
									<h4>
										No. of Items: @VM.TotalItems
									</h4>
								</div>

							</div>
						
							<button type="submit" class="btn btn-success m-4">
								Looks Good? Place Order!
							</button>
						</div>
					</EditForm>
				</div>
			</div>
		</div>
	}
	else
	{
		<div class="p-4">
			<div class="alert alert-warning">
				Your cart is empty ! Please add items to cart.
			</div>
		</div>
	}
}

@code {
	protected override void OnInitialized()
	{
		VM.StateChanged = StateHasChanged;
	}

	protected override async Task OnInitializedAsync()
	{
		await VM.InitializeAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		await VM.AfterRenderAsync(firstRender);
	}
}