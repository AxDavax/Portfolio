@page "/order/confirmation"
@using ECommerce.ClientPortal.ViewModels.Orders
@inject OrderConfirmationVM VM

@if (VM.IsProcessing)
{
	<div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center">
		<img src="/images/loading.gif" alt="loading" />
	</div>
}
else if (VM.OrderHeader is null)
{
	<div class="text-center mt-5">
		<h3 class="text-danger">Unable to load your order.</h3>
	</div>
}
else
{
	<div class="text-center">
		<h1 class="pt-4 text-success">You are one stop closer to delicious food!</h1>
		<p>Your order is confirmed! Please note your order ID for any questions.</p>
		<p>Order ID: <b>@VM.OrderHeader.Id</b></p>
		<hr />
		<img src="/images/lawn_leaf.jpg" width="40%" />
		<hr />
	</div>
}

@code {
	[Parameter]
	[SupplyParameterFromQuery(Name = "session_id")]
	public string session_id { get; set; }

	private bool _initialized;

	protected override async Task OnParametersSetAsync()
	{
		if (_initialized)
			return;

		if (string.IsNullOrWhiteSpace(session_id))
			return;

		_initialized = true;

		VM.SessionId = session_id;
		await VM.LoadOrderAsync();

		StateHasChanged();
	}
}