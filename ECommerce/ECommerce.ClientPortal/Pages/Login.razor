@page "/login"
@using ECommerce.ClientPortal.ViewModels.Auth
@inject LoginVM VM

<h3>Sign in</h3>

@if (VM.IsProcessing)
{
    <div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}

@if (!string.IsNullOrEmpty(VM.ErrorMessage))
{
    <div class="alert alert-danger">@VM.ErrorMessage</div>
}

<EditForm Model="VM.Model" OnValidSubmit="VM.LoginAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="VM.Model.Email" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <InputText class="form-control" @bind-Value="VM.Model.Password" type="password" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@VM.IsProcessing">
        @(VM.IsProcessing ? "Processing..." : "Log in")
    </button>

    <p class="mt-3 text-center">
        Don't have an account?
        <a href="/register">Sign up</a>
    </p>
</EditForm>