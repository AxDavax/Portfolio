@page "/"
@using System.Globalization
@using ECommerce.ClientPortal.Services.API.Interfaces
@using ECommerce.ClientPortal.Services.State
@using ECommerce.ClientPortal.ViewModels.Core
@using ECommerce.ClientPortal.ViewModels.Home
@inject IShoppingCartApi cartApi
@inject IProductApi productApi
@inject ICategoryApi categoryApi
@inject NavigationManager navigation
@inject SharedStateService sharedStateService
@inject IJSRuntime js
@inject AuthUserVM authUser

<PageTitle>Home</PageTitle>

@if (VM is null)
{
    <div class="position-absolute w-75 h-75 d-flex flex-column align-items-center bg-white justify-content-center" style="z-index: -1;">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}
else if (VM.IsProcessing)
{
    <div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center" style="z-index: -1;">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}
else
{
    <div class="container-fluid px-0 m-0 full-width">
        <div class="jumbotron-custom">
            <div class="m-auto d-flex align-items-center" style="width: 400px; height: 50vh;">

                <div class="d-flex align-items-center" style="width: 100%;">
                    <input type="text" class="form-control rounded-pill"
                           @bind:event="oninput" @bind:get="VM.SearchText" @bind:set="VM.FilterProductByName!"
                           placeholder="Search for Food Items!"
                           style="width: 100%; padding: 20px;">
                    <span style="position: relative; left: -43px;"><i class="bi bi-search"></i></span>
                </div>
            </div>
        </div>

        <div class="content px-4 m-2">
            <ul class="nav nav-underline justify-content-center mb-2">
                <li class="nav-item">
                    <span class="nav-link @VM.GetActiveTabClass(0)" href="#" style="cursor: pointer"
                          @onclick="() => VM.FilterProducts(0)">All</span>
                </li>
                @foreach (var category in VM.Categories)
                {
                    <li class="nav-item">
                        <span class="nav-link @VM.GetActiveTabClass(category.Id)" href="#" style="cursor: pointer"
                              @onclick="() => VM.FilterProducts(category.Id)">@category.Name</span>
                    </li>
                }
            </ul>
            <div class="row mt-4 mx-1">
                @foreach (var prod in VM.FilteredProducts)
                {
                    <div class="col-12 col-md-6 col-lg-4 pe-3 mb-5">
                        <div class="card">
                            <div class="mt-3 mb-2 row">
                                <div class="col-6 px-3">
                                    @if (!string.IsNullOrEmpty(prod.SpecialTag))
                                    {
                                        <i class="bi bi-star btn btn-outline-success disabled"> @prod.SpecialTag</i>
                                    }
                                </div>
                                <div class="col-6 text-end text-danger px-3 h3">
                                    @prod.Price.ToString("C", CultureInfo.GetCultureInfo("fr-ca"))
                                </div>
                            </div>
                            <div class="text-center">
                                @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                {
                                    <img class="card-img-top img-thumbnail img-rounded w-50 mt-2" src="@prod.ImageUrl" style="">
                                }
                                else
                                {
                                    <img class="card-img-top img-thumbnail img-rounded w-50 mt-2" src="images/default.png" style="">
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title text-center lead text-success">@prod.Name</h5>
                                <p class="card-text mt-2">@((MarkupString)prod.Description)</p>
                                <div class="text-center">
                                    <div class="m-lg-auto p-2">
                                        <button class="btn btn-success w-100 add-to-cart-outline"
                                                @onclick="() => VM.AddOrderItem(prod)">
                                            <i class="bi bi-cart3 text-right"> Add to cart</i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private HomeVM VM;

    protected override void OnInitialized()
    {
        VM = new HomeVM(
            cartApi,
            productApi,
            categoryApi,
            navigation,
            sharedStateService,
            js,
            authUser
        );

        VM.StateChanged = StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await VM.AfterRenderAsync(firstRender);
    }
}