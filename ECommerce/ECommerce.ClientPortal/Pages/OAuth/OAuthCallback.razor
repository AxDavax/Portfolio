@page "/oauth/{provider}/callback"
@using ECommerce.ClientPortal.ViewModels.OAuth
@inject CallbackVM VM

@code {
    [Parameter]
    public string Provider { get; set; }

    private void StateHasChangedSafe() => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        VM.StateChanged += StateHasChangedSafe;
        await VM.InitializedAsync(Provider);
    }

    public void Dispose()
    {
        VM.StateChanged -= StateHasChangedSafe;
    }
}