@page "/Auth/Register"
@using ECommerce.ClientPortal.ViewModels.Auth
@inject RegisterVM VM

<PageTitle>Register</PageTitle>

@if (VM.IsProcessing)
{
    <div class="position-absolute w-100 vh-100 d-flex flex-column align-items-center bg-white justify-content-center">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}

@if (!string.IsNullOrEmpty(VM.ErrorMessage))
{
    <div class="alert alert-danger">@VM.ErrorMessage</div>
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card bg-light" style="min-width: 28rem;">
        <div class="card-body">
            <h5 class="card-title text-center display-6">Sign Up</h5> 
            <EditForm Model="VM.Request" OnValidSubmit="VM.RegisterAsync">
                <DataAnnotationsValidator />
                <hr />

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Request.FirstName" id="VM.Model.FirstName" autocomplete="firstname" aria-required="true" />
                    <label for="VM.Model.FirstName">First Name</label>
                    <ValidationMessage For="() => VM.Request.FirstName" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Request.LastName" id="VM.Model.LastName" autocomplete="lastname" aria-required="true" />
                    <label for="VM.Model.LastName">Last Name</label>
                    <ValidationMessage For="() => VM.Request.LastName" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Request.Email" id="VM.Model.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label for="VM.Model.Email">Email</label>
                    <ValidationMessage For="() => VM.Request.Email" class="text-danger" />                        
                </div>

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Request.Password" type="password" id="VM.Model.Password" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label for="VM.Model.Password">Password</label>
                    <ValidationMessage For="() => VM.Request.Password" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Request.ConfirmPassword" type="password" id="VM.Model.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="confirm password" />
                    <label for="VM.Model.ConfirmPassword">Confirm Password</label>
                    <ValidationMessage For="() => VM.Request.ConfirmPassword" class="text-danger" />
                </div>

                <button class="w-100 btn btn-lg btn-primary" type="submit" disabled="@VM.IsProcessing">
                    @(VM.IsProcessing ? "Processing..." : "Register")
                </button>

                <p class="mt-3 text-center">
                    Already have an account?
                    <a href="/Auth/login">Sign in</a>
                </p>
            </EditForm>
        </div>
    </div>
</div>