@page "/Auth/Forgot-password"
@using ECommerce.ClientPortal.ViewModels.Auth
@inject ForgotPasswordVM VM

<PageTitle>Forgot Password</PageTitle>

@if (!string.IsNullOrEmpty(VM.Message))
{
    <div class="alert alert-info">@VM.Message</div>
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card bg-light" style="min-width: 28rem;">
        <div class="card-body">
            <h4 class="card-title text-center display-6">Forgot Password</h4>
            <EditForm Model="VM" OnValidSubmit="VM.SubmitAsync">
                <DataAnnotationsValidator />
                <hr />

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.Email" id="VM.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label for="VM.Email" class="form-label">Email</label>
                    <ValidationMessage For="() => VM.Email" class="text-danger" />
                </div>

                <button class="w-100 btn btn-lg btn-primary" disabled="@VM.IsProcessing">
                    @if (VM.IsProcessing)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>