@page "/Auth/Reset-password"
@using ECommerce.ClientPortal.ViewModels.Auth
@inject ResetPasswordVM VM
@inject NavigationManager Nav

<PageTitle>Reset Password</PageTitle>

@if (!string.IsNullOrEmpty(VM.Message))
{
    <div class="alert alert-info">@VM.Message</div>
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card bg-light" style="min-width: 28rem;">
        <div class="card-body">
            <h4 class="card-title text-center display-6">Reset Password</h4>
            <EditForm Model="VM" OnValidSubmit="VM.SubmitAsync">
                <DataAnnotationsValidator />
                <hr />

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.NewPassword" type="password" id="VM.Model.Password" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label for="VM.Model.Password" class="form-label">New Password</label>
                    <ValidationMessage For="() => VM.NewPassword" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText class="form-control" @bind-Value="VM.ConfirmPassword" type="password" id="VM.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="confirm password" />
                    <label for="VM.ConfirmPassword" class="form-label">Confirm Password</label>
                    <ValidationMessage For="() => VM.ConfirmPassword" class="text-danger" />
                </div>


                <button class="w-100 btn btn-lg btn-primary" disabled="@VM.IsProcessing">
                    @if (VM.IsProcessing)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        VM.Token = query["token"] ?? string.Empty;
    }
}